# Local dev: cp .env.example .env and fill in values.
#
# Cloudflare production (Workers & Pages → website → Settings → Variables and Secrets):
#   RESEND_API_KEY  → Secret (runtime only — do NOT add to CI build variables)
#   All other keys  → Variables (set for runtime; SITE_URL and CONTACT_EMAIL also at build
#                     time if you want them baked into prerendered pages)

# ── Secrets ───────────────────────────────────────────────────

# Email sending via Resend (https://resend.com) — free tier: 3,000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Variables ─────────────────────────────────────────────────

# Where form submissions are delivered (inbound routing also targets this address)
CONTACT_EMAIL=info@clustertecnologicoazul.org

# Canonical site URL (SEO, email footer, astro.config `site`)
SITE_URL=https://clustertecnologicoazul.org

# Outbound "from" address for Resend (domain must be verified in Resend)
NOREPLY_EMAIL=noreply@clustertecnologicoazul.org

# Display name in the From header
FROM_NAME=Cluster Tecnológico Azul
