---
const year = new Date().getFullYear();

const links = [
  { href: '/#nosotros', label: 'Nosotros' },
  { href: '/#iniciativas', label: 'Iniciativas' },
  { href: '/#valores', label: 'Valores' },
  { href: '/unirse', label: 'Únete' },
  { href: '/contacto', label: 'Contacto' },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-logo-text">Cluster Tecnológico Azul</span>
      <p class="footer-slogan">Impulsando la innovación tecnológica en Azul 🚀</p>
      <p class="footer-location">Azul, Buenos Aires, Argentina</p>
    </div>

    <nav class="footer-nav" aria-label="Navegación del pie de página">
      <ul>
        {links.map(link => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="footer-social">
      <a href="https://github.com/clustertecnologicoazul" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>© {year} Cluster Tecnológico Azul. Hecho con orgullo en Azul.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--clr-border);
    margin-top: 6rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 3rem;
    align-items: start;
    padding-block: 3rem;
  }

  .footer-logo-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--clr-text);
    display: block;
    margin-bottom: 0.5rem;
  }

  .footer-slogan {
    font-size: 0.9rem;
    color: var(--clr-text-soft);
    margin-bottom: 0.25rem;
  }

  .footer-location {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--clr-muted);
  }

  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-nav a {
    font-size: 0.88rem;
    color: var(--clr-text-soft);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-nav a:hover {
    color: var(--clr-text);
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    padding-top: 0.1rem;
  }

  .footer-social a {
    color: var(--clr-muted);
    transition: color var(--transition);
    display: flex;
    align-items: center;
  }

  .footer-social a:hover {
    color: var(--clr-cyan);
  }

  .footer-bottom {
    border-top: 1px solid var(--clr-border);
    padding-block: 1.25rem;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: var(--clr-muted);
    font-family: var(--font-mono);
  }

  @media (max-width: 640px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding-block: 2rem;
    }
  }
</style>
