---
const year = new Date().getFullYear();

const links = [
  { href: '/#nosotros', label: 'Nosotros' },
  { href: '/#iniciativas', label: 'Iniciativas' },
  { href: '/#valores', label: 'Valores' },
  { href: '/unirse', label: 'Unite' },
  { href: '/contacto', label: 'Contacto' },
];
---

<footer class="site-footer">
