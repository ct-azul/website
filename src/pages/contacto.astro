---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { CONTACT_EMAIL } from '../config';
---

<Layout
  title="Contacto"
  description="Ponete en contacto con el Cluster Tecnológico Azul. Respondemos a la brevedad."
>
  <div class="page-hero">
    <div class="container">
      <span class="section-label">Hablemos</span>
      <h1>Contacto</h1>
      <p class="page-subtitle">
        ¿Tenés una pregunta, propuesta o idea para el cluster?
        Escribinos y te respondemos a la brevedad.
      </p>
    </div>
  </div>

  <div class="page-body">
    <div class="container page-grid">
      <aside class="contact-info">
        <div class="info-block">
          <h3>Información de contacto</h3>
          <div class="contact-item">
            <span class="contact-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 8l7.89 5.26a2 2 0 0 0 2.22 0L21 8M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2z"/>
              </svg>
            </span>
            <div>
              <span class="contact-label">Email</span>
              <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 0 1-2.827 0l-4.244-4.243a8 8 0 1 1 11.314 0z"/>
                <path d="M15 11a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
              </svg>
            </span>
            <div>
              <span class="contact-label">Ubicación</span>
              <span>Azul, Buenos Aires, Argentina</span>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
            </span>
            <div>
              <span class="contact-label">GitHub</span>
              <a href="https://github.com/clustertecnologicoazul" target="_blank" rel="noopener noreferrer">@clustertecnologicoazul</a>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </span>
            <div>
              <span class="contact-label">LinkedIn</span>
              <a href="https://linkedin.com/company/clustertecnologicoazul" target="_blank" rel="noopener noreferrer">Cluster Tecnológico Azul</a>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
              </svg>
            </span>
            <div>
              <span class="contact-label">Instagram</span>
              <a href="https://instagram.com/clustertecnologicoazul" target="_blank" rel="noopener noreferrer">@clustertecnologicoazul</a>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M7.953 15.066c-.08.163-.08.324-.08.486.08.517.528.897 1.052.897h2.4v4.02c0 .65.527 1.176 1.176 1.176s1.176-.527 1.176-1.176v-4.02h2.4c.525 0 .973-.38 1.054-.897 0-.162 0-.323-.082-.486l-3.55-6.54-.002-.003a1.07 1.07 0 0 0-.946-.571 1.07 1.07 0 0 0-.945.574l-3.553 6.54zm3.553-9.925 3.347 3.347a1.01 1.01 0 0 0 1.43 0l.001-.001a1.013 1.013 0 0 0 0-1.43L13.43 4.304a1.012 1.012 0 0 0-1.43 0l-1.493 1.494V3.472A1.176 1.176 0 0 0 9.33 2.296a1.176 1.176 0 0 0-1.177 1.176V5.8L6.66 4.304a1.012 1.012 0 0 0-1.43 0L2.716 6.817a1.013 1.013 0 0 0 0 1.43l.001.001a1.01 1.01 0 0 0 1.43 0l3.347-3.347v1.323a1.012 1.012 0 0 0 0 1.43L8.21 8.369a1.012 1.012 0 0 0 1.43 0l.713-.713V7.79c0-.32.136-.618.352-.832l.8-.817z"/>
              </svg>
            </span>
            <div>
              <span class="contact-label">Linktree</span>
              <a href="https://linktr.ee/clustertecnologicoazul" target="_blank" rel="noopener noreferrer">linktr.ee/clustertecnologicoazul</a>
            </div>
          </div>
        </div>

        <div class="info-block response-time">
          <div class="response-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
            </svg>
          </div>
          <p>Respondemos en menos de <strong>48 horas</strong> durante días hábiles.</p>
        </div>
      </aside>

      <div class="form-container">
        <div id="form-success" class="form-feedback success" hidden role="alert">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
          </svg>
          <h3>¡Mensaje enviado!</h3>
          <p>Gracias por escribirnos. Te respondemos pronto.</p>
        </div>

        <div id="form-error" class="form-feedback error" hidden role="alert">
          <p>Ocurrió un error al enviar el mensaje. Por favor intentá de nuevo o escribinos directamente a <a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>.</p>
        </div>

        <form id="contact-form" class="form" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="nombre">Nombre *</label>
              <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" required autocomplete="name" maxlength="200" />
            </div>
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" placeholder="tu@email.com" required autocomplete="email" />
            </div>
          </div>

          <div class="form-group">
            <label for="asunto">Asunto *</label>
            <select id="asunto" name="asunto" required>
              <option value="" disabled selected>¿Sobre qué querés escribir?</option>
              <option value="informacion">Información general</option>
              <option value="colaboracion">Propuesta de colaboración</option>
              <option value="evento">Organizar un evento</option>
              <option value="prensa">Prensa / medios</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div class="form-group">
            <label for="mensaje">Mensaje *</label>
            <textarea id="mensaje" name="mensaje" placeholder="Contanos tu consulta, propuesta o idea..." rows="6" required maxlength="5000"></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-submit" id="submit-btn">
            <span class="btn-label">Enviar mensaje</span>
            <span class="btn-loading" hidden>
              <svg class="spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
              </svg>
              Enviando...
            </span>
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successEl = document.getElementById('form-success')!;
  const errorEl = document.getElementById('form-error')!;

  const btnLabel   = submitBtn.querySelector<HTMLElement>('.btn-label');
  const btnLoading = submitBtn.querySelector<HTMLElement>('.btn-loading');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }

    submitBtn.disabled = true;
    submitBtn.setAttribute('aria-disabled', 'true');
    form.setAttribute('aria-busy', 'true');
    btnLabel?.setAttribute('hidden', '');
    btnLoading?.removeAttribute('hidden');
    errorEl.hidden = true;

    try {
      const res = await fetch('/api/contacto', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(form))),
      });

      if (res.ok) {
        form.hidden = true;
        successEl.hidden = false;
        successEl.setAttribute('tabindex', '-1');
        successEl.focus();
      } else {
        throw new Error('Error en el servidor');
      }
    } catch {
      errorEl.hidden = false;
      submitBtn.disabled = false;
      submitBtn.removeAttribute('aria-disabled');
      form.removeAttribute('aria-busy');
      btnLabel?.removeAttribute('hidden');
      btnLoading?.setAttribute('hidden', '');
    }
  });
</script>

<style>
  .page-hero {
    padding-top: calc(68px + 4rem);
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--clr-border);
  }

  .page-hero .section-label { margin-bottom: 1rem; }

  .page-hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    color: var(--clr-text);
    margin-bottom: 1rem;
  }

  .page-subtitle {
    color: var(--clr-text-soft);
    font-size: 1.05rem;
    max-width: 540px;
    line-height: 1.75;
  }

  .page-body { padding-block: 4rem; }

  .page-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Info sidebar */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: calc(68px + 2rem);
  }

  .info-block {
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
  }

  .info-block h3 {
    font-size: 0.9rem;
    color: var(--clr-text);
    margin-bottom: 1.25rem;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .contact-item:last-child { margin-bottom: 0; }

  .contact-icon {
    width: 30px;
    height: 30px;
    background: var(--clr-surface-2);
    border: 1px solid var(--clr-border);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-cyan);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .contact-item > div {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .contact-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--clr-muted);
  }

  .contact-item a,
  .contact-item span:last-child {
    font-size: 0.875rem;
    color: var(--clr-text-soft);
  }

  .contact-item a:hover { color: var(--clr-cyan); }

  .response-time {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    border-color: var(--clr-blue-dim);
    background: var(--clr-blue-glow);
  }

  .response-icon {
    color: var(--clr-blue);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .response-time p {
    font-size: 0.85rem;
    color: var(--clr-text-soft);
    line-height: 1.6;
  }

  .response-time strong { color: var(--clr-text); }

  /* Form */
  .form-container {
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .btn-submit {
    align-self: flex-start;
    min-width: 180px;
    justify-content: center;
  }

  .spinner { animation: spin 1s linear infinite; }

  @keyframes spin { to { transform: rotate(360deg); } }

  .form-feedback {
    border-radius: var(--radius-md);
    padding: 2rem;
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .form-feedback.success {
    background: rgba(0, 212, 200, 0.07);
    border: 1px solid rgba(0, 212, 200, 0.3);
    color: var(--clr-cyan);
  }

  .form-feedback.success svg { margin-inline: auto; margin-bottom: 0.75rem; }
  .form-feedback.success h3 { color: var(--clr-text); margin-bottom: 0.5rem; }
  .form-feedback.success p { color: var(--clr-text-soft); font-size: 0.95rem; }

  .form-feedback.error {
    background: rgba(239, 68, 68, 0.07);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: var(--clr-text-soft);
    font-size: 0.9rem;
  }

  @media (max-width: 840px) {
    .page-grid { grid-template-columns: 1fr; }
    .contact-info { position: static; }
  }

  @media (max-width: 540px) {
    .form-container { padding: 1.5rem; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
